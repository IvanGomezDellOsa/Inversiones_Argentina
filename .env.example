# Configuración de variables de entorno para inversionesargentina.com.ar

# Credenciales de Google AI Studio (Gemini 2.5 Flash + gemini-embedding-2-preview)
GEMINI_API_KEY=tu_api_key_aqui

# API Token de Apify (Extracción de X)
APIFY_API_TOKEN=tu_token_apify_aqui

# Cadena de conexión Neon PostgreSQL con pgvector habilitado
DATABASE_URL=postgresql://user:password@host/dbname
 
# Configuración del Bot de Telegram para notificaciones
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui
TELEGRAM_CHANNEL_ID=@inversiones_en_argentina

# API key pública de Google Sheets del portal RIGI (gob.ar). No es un secreto propio:
# está en el JS público de argentina.gob.ar/economia/rigi. Si falta, la fuente RIGI se omite.
RIGI_API_KEY=api_key_publica_del_portal_rigi